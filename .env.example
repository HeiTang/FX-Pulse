# FX Pulse Configuration
# Copy to .env and adjust as needed. All vars prefixed with FX_.

# FX_BASE_CURRENCY=TWD
# FX_CURRENCIES=["USD","JPY","EUR","GBP","HKD","AUD","KRW","SGD"]
# FX_DATA_FILE=/path/to/rates.json

# Scraper
# FX_SCRAPER_TIMEOUT=20
# FX_SCRAPER_MAX_RETRIES=5
# FX_SCRAPER_DELAY_MIN=1.5
# FX_SCRAPER_DELAY_MAX=3.5
# FX_SCRAPER_BACKOFF_CAP=60.0

# API Server
# FX_CORS_ORIGINS=["http://localhost:4321"]
# FX_API_HOST=0.0.0.0
# FX_API_PORT=8000
