---
import '../styles/global.css';
import ratesData from '../data/rates.json';

const { meta, rates } = ratesData;
const dates = Object.keys(rates).sort();
const latestDate = dates[dates.length - 1];
const latestDay = rates[latestDate as keyof typeof rates] ?? {};

const currencyInfo: Record<string, { flag: string; name: string }> = {
  USD: { flag: '🇺🇸', name: '美元' },
  JPY: { flag: '🇯🇵', name: '日圓' },
  EUR: { flag: '🇪🇺', name: '歐元' },
  GBP: { flag: '🇬🇧', name: '英鎊' },
  HKD: { flag: '🇭🇰', name: '港幣' },
  AUD: { flag: '🇦🇺', name: '澳幣' },
  KRW: { flag: '🇰🇷', name: '韓元' },
  SGD: { flag: '🇸🇬', name: '新加坡幣' },
};

type RateEntry = { rate: number; reverse: number };
const allSources = ['VISA', 'Mastercard', 'JCB'] as const;
const sourceRates: Record<string, Record<string, RateEntry>> = {};
for (const src of allSources) {
  sourceRates[src] = (latestDay as Record<string, Record<string, RateEntry>>)?.[src] ?? {};
}

function fmt(rate: number): string {
  return rate >= 1 ? rate.toFixed(4) : rate.toFixed(6);
}

// Per-currency: which source has the lowest rate (best for cardholder)
function rateRank(currency: string): Record<string, 'best' | 'worst' | null> {
  const vals = allSources
    .map((s) => ({ src: s, rate: sourceRates[s][currency]?.rate }))
    .filter((v) => v.rate != null && v.rate > 0);
  if (vals.length < 2) return Object.fromEntries(allSources.map((s) => [s, null]));
  const min = Math.min(...vals.map((v) => v.rate!));
  const max = Math.max(...vals.map((v) => v.rate!));
  const result: Record<string, 'best' | 'worst' | null> = {};
  for (const s of allSources) {
    const r = sourceRates[s][currency]?.rate;
    if (r === min) result[s] = 'best';
    else if (r === max) result[s] = 'worst';
    else result[s] = null;
  }
  return result;
}

const ratesJson = JSON.stringify(ratesData);
---

<html lang="zh-Hant">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>FX Pulse — 匯率脈動</title>
  </head>
  <body class="bg-gray-950 text-gray-100 min-h-screen antialiased">
    <!-- Header -->
    <header class="border-b border-gray-800 px-6 py-4">
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-3">
          <svg viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 shrink-0" aria-hidden="true">
            <g fill="none" stroke-linecap="round">
              <path d="M 10 50 C 23 24, 37 24, 50 50 S 77 76, 90 50" stroke="#4D9EFF" stroke-width="3.5"/>
              <path d="M 10 50 C 23 32, 37 32, 50 50 S 77 68, 90 50" stroke="#4D9EFF" stroke-width="2.5" opacity="0.5"/>
              <path d="M 10 50 C 23 40, 37 40, 50 50 S 77 60, 90 50" stroke="#4D9EFF" stroke-width="1.5" opacity="0.22"/>
            </g>
            <circle cx="10" cy="50" r="3.5" fill="#4D9EFF"/>
            <circle cx="90" cy="50" r="3.5" fill="#4D9EFF"/>
          </svg>
          <h1 class="text-xl font-bold tracking-tight">FX Pulse</h1>
        </div>
        <div class="text-sm text-gray-400">
          更新時間：<time class="text-gray-300">{latestDate}</time>
        </div>
      </div>
    </header>

    <main class="max-w-7xl mx-auto px-6 py-8 space-y-8">
      <!-- Source Tabs -->
      <div class="flex gap-2">
        <button data-source="all" class="source-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all bg-indigo-500/20 text-indigo-400 border border-indigo-500/50">
          全部
        </button>
        <button data-source="VISA" class="source-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all text-gray-400 border border-gray-700 hover:border-gray-500">
          VISA
        </button>
        <button data-source="Mastercard" class="source-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all text-gray-400 border border-gray-700 hover:border-gray-500">
          Mastercard
        </button>
        <button data-source="JCB" class="source-tab px-4 py-1.5 rounded-full text-sm font-medium transition-all text-gray-400 border border-gray-700 hover:border-gray-500">
          JCB
        </button>
      </div>

      <!-- Rate Cards -->
      <section>
        <h2 class="text-sm font-medium text-gray-400 mb-4 uppercase tracking-wider">即時匯率</h2>
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
          {meta.currencies.map((currency: string) => {
            const info = currencyInfo[currency];
            const rank = rateRank(currency);
            const sourceLabels = [
              { key: 'VISA', label: 'VISA', color: 'text-indigo-400' },
              { key: 'Mastercard', label: 'Mastercard', color: 'text-amber-400' },
              { key: 'JCB', label: 'JCB', color: 'text-rose-400' },
            ];
            return (
              <button
                data-currency={currency}
                class="currency-card group relative bg-gray-900 border border-gray-800 rounded-xl p-4 text-left transition-all hover:border-indigo-500/50 hover:bg-gray-900/80 cursor-pointer"
              >
                <div class="flex items-center gap-2 mb-3">
                  <span class="text-lg">{info?.flag}</span>
                  <span class="text-sm font-medium text-gray-300">{currency}</span>
                  <span class="text-xs text-gray-500">{info?.name}</span>
                </div>
                {sourceLabels.map((s) => {
                  const rate = sourceRates[s.key]?.[currency];
                  const r = rank[s.key];
                  const rateClass = r === 'best' ? 'text-emerald-400' : r === 'worst' ? 'text-red-400' : 'text-gray-100';
                  return (
                    <div class="flex items-center justify-between mb-1 source-row" data-row-source={s.key}>
                      <span class:list={['text-xs', s.color]}>{s.label}</span>
                      <span class:list={['rate-value text-base font-mono font-semibold', rateClass]}>
                        {rate ? fmt(rate.rate) : '—'}
                      </span>
                    </div>
                  );
                })}
              </button>
            );
          })}
        </div>
      </section>

      <!-- Chart Section -->
      <section>
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-medium text-gray-400 uppercase tracking-wider">走勢圖表</h2>
          <div id="active-currency" class="text-sm font-medium text-indigo-400"></div>
        </div>
        <div class="bg-gray-900 border border-gray-800 rounded-xl p-4">
          <div id="chart" class="w-full" style="height: 400px;"></div>
          <div id="chart-placeholder" class="hidden w-full flex items-center justify-center text-gray-500 text-sm" style="height: 400px;">
            資料累積中，需至少 2 天數據才能繪製走勢圖
          </div>
        </div>
      </section>

      <!-- Footer -->
      <footer class="text-center text-xs text-gray-600 pb-8">
        資料來源：VISA / Mastercard / JCB Exchange Rate · 基準貨幣：TWD
      </footer>
    </main>

    <script define:vars={{ ratesJson }}>
      window.__FX_RATES__ = JSON.parse(ratesJson);
    </script>

    <script>
      import * as echarts from 'echarts/core';
      import { LineChart } from 'echarts/charts';
      import {
        TooltipComponent,
        GridComponent,
        DataZoomComponent,
        LegendComponent,
      } from 'echarts/components';
      import { CanvasRenderer } from 'echarts/renderers';

      echarts.use([
        LineChart,
        TooltipComponent,
        GridComponent,
        DataZoomComponent,
        LegendComponent,
        CanvasRenderer,
      ]);

      const ratesData = (window as any).__FX_RATES__ ?? {};
      const dates = Object.keys(ratesData.rates ?? {}).sort();
      const sources = ['VISA', 'Mastercard', 'JCB'] as const;

      const currencyNames = {
        USD: '美元', JPY: '日圓', EUR: '歐元', GBP: '英鎊',
        HKD: '港幣', AUD: '澳幣', KRW: '韓元', SGD: '新加坡幣',
      } as Record<string, string>;

      const sourceColors = {
        VISA: { line: '#6366f1', area0: 'rgba(99, 102, 241, 0.25)', area1: 'rgba(99, 102, 241, 0.02)' },
        Mastercard: { line: '#f59e0b', area0: 'rgba(245, 158, 11, 0.20)', area1: 'rgba(245, 158, 11, 0.02)' },
        JCB: { line: '#f43f5e', area0: 'rgba(244, 63, 94, 0.20)', area1: 'rgba(244, 63, 94, 0.02)' },
      } as Record<string, { line: string; area0: string; area1: string }>;

      let chart: ReturnType<typeof echarts.init> | null = null;
      let activeCurrency = 'USD';
      let activeSource: string = 'all';

      function getSeriesData(currency: string, source: string) {
        return dates.map((d: string) => ratesData.rates[d]?.[source]?.[currency]?.rate ?? null);
      }

      function getVisibleSources(): string[] {
        if (activeSource === 'all') return ['VISA', 'Mastercard', 'JCB'];
        return [activeSource];
      }

      function buildOption(currency: string) {
        const visible = getVisibleSources();
        const seriesList = visible.map((src) => {
          const colors = sourceColors[src];
          return {
            name: src,
            type: 'line' as const,
            data: getSeriesData(currency, src),
            smooth: true,
            symbol: 'circle',
            symbolSize: 5,
            lineStyle: { color: colors.line, width: 2 },
            itemStyle: { color: colors.line },
            areaStyle: {
              color: new echarts.graphic.LinearGradient(0, 0, 0, 1, [
                { offset: 0, color: colors.area0 },
                { offset: 1, color: colors.area1 },
              ]),
            },
          };
        });

        return {
          backgroundColor: 'transparent',
          grid: { left: 60, right: 20, top: 40, bottom: 50 },
          legend: {
            show: visible.length > 1,
            top: 4,
            right: 0,
            textStyle: { color: '#9ca3af', fontSize: 12 },
            itemWidth: 16,
            itemHeight: 2,
          },
          tooltip: {
            trigger: 'axis' as const,
            backgroundColor: 'rgba(15, 15, 25, 0.95)',
            borderColor: '#333',
            textStyle: { color: '#e5e7eb', fontSize: 12 },
            formatter(params: any) {
              const items = Array.isArray(params) ? params : [params];
              let html = '<b>' + items[0].name + '</b>';
              for (const p of items) {
                const val = p.value != null ? Number(p.value).toFixed(4) : '—';
                const dot = '<span style="display:inline-block;width:8px;height:8px;border-radius:50%;background:' + p.color + ';margin-right:6px;"></span>';
                html += '<br/>' + dot + p.seriesName + ': <b>' + val + '</b>';
              }
              html += '<br/><span style="color:#6b7280">1 ' + currency + ' → TWD</span>';
              return html;
            },
          },
          xAxis: {
            type: 'category' as const,
            data: dates,
            axisLabel: { color: '#6b7280', fontSize: 11 },
            axisLine: { lineStyle: { color: '#374151' } },
          },
          yAxis: {
            type: 'value' as const,
            scale: true,
            splitLine: { lineStyle: { color: '#1f2937' } },
            axisLabel: { color: '#6b7280', fontSize: 11 },
          },
          dataZoom: [{ type: 'inside' as const, start: 0, end: 100 }],
          series: seriesList,
        };
      }

      function renderChart(currency: string) {
        const chartEl = document.getElementById('chart')!;
        const placeholder = document.getElementById('chart-placeholder')!;

        if (dates.length < 2) {
          chartEl.classList.add('hidden');
          placeholder.classList.remove('hidden');
          return;
        }

        chartEl.classList.remove('hidden');
        placeholder.classList.add('hidden');

        if (!chart) {
          chart = echarts.init(chartEl);
        }
        chart.setOption(buildOption(currency), true);
      }

      function setActiveCurrency(currency: string) {
        activeCurrency = currency;

        document.querySelectorAll('.currency-card').forEach((el) => {
          const c = (el as HTMLElement).dataset.currency;
          if (c === currency) {
            el.classList.add('border-indigo-500', 'bg-gray-800/50');
            el.classList.remove('border-gray-800');
          } else {
            el.classList.remove('border-indigo-500', 'bg-gray-800/50');
            el.classList.add('border-gray-800');
          }
        });

        const label = document.getElementById('active-currency');
        if (label) {
          label.textContent = currency + ' — ' + (currencyNames[currency] ?? currency);
        }

        renderChart(currency);
      }

      function setActiveSource(source: string) {
        activeSource = source;

        // Update tab styles
        document.querySelectorAll('.source-tab').forEach((el) => {
          const s = (el as HTMLElement).dataset.source;
          if (s === source) {
            el.classList.add('bg-indigo-500/20', 'text-indigo-400', 'border-indigo-500/50');
            el.classList.remove('text-gray-400', 'border-gray-700');
          } else {
            el.classList.remove('bg-indigo-500/20', 'text-indigo-400', 'border-indigo-500/50');
            el.classList.add('text-gray-400', 'border-gray-700');
          }
        });

        // Toggle card rows visibility
        document.querySelectorAll('.source-row').forEach((el) => {
          const rowSrc = (el as HTMLElement).dataset.rowSource;
          if (source === 'all' || rowSrc === source) {
            (el as HTMLElement).style.display = '';
          } else {
            (el as HTMLElement).style.display = 'none';
          }
        });

        // Toggle rate value colors: show comparison colors only in "all" mode
        document.querySelectorAll('.rate-value').forEach((el) => {
          const htmlEl = el as HTMLElement;
          if (source === 'all') {
            // Restore original classes (stored via data attr on first run)
            const orig = htmlEl.dataset.origClass;
            if (orig) htmlEl.className = orig;
          } else {
            // Store original and reset to neutral
            if (!htmlEl.dataset.origClass) {
              htmlEl.dataset.origClass = htmlEl.className;
            }
            htmlEl.className = htmlEl.className
              .replace(/text-emerald-400/g, 'text-gray-100')
              .replace(/text-red-400/g, 'text-gray-100');
          }
        });

        renderChart(activeCurrency);
      }

      // Source tab clicks
      document.querySelectorAll('.source-tab').forEach((el) => {
        el.addEventListener('click', () => {
          const source = (el as HTMLElement).dataset.source;
          if (source) setActiveSource(source);
        });
      });

      // Currency card clicks
      document.querySelectorAll('.currency-card').forEach((el) => {
        el.addEventListener('click', () => {
          const currency = (el as HTMLElement).dataset.currency;
          if (currency) setActiveCurrency(currency);
        });
      });

      window.addEventListener('resize', () => chart?.resize());

      // Init
      setActiveCurrency('USD');
    </script>
  </body>
</html>
